{% extends 'base.html.twig' %}

{% block title %}Conversation avec {{ otherUser.username }} | SymfoConnect{% endblock %}

{% block body %}
    <div class="feed-head">
        <h1 class="section-title">Conversation avec {{ otherUser.username }}</h1>
        <a class="menu-link" href="{{ path('app_message_index') }}">Retour conversations</a>
    </div>

    {% if messages is empty %}
        <div class="card">
            <p>Aucun message pour le moment.</p>
        </div>
    {% else %}
        {% for message in messages %}
            <article class="card">
                <p class="post-meta">
                    <strong>{{ message.sender.id == app.user.id ? 'Vous' : message.sender.username }}</strong>
                    · {{ message.createdAt|date('d/m/Y H:i') }}
                    {% if message.recipient.id == app.user.id and not message.isRead %}
                        · non lu
                    {% endif %}
                </p>
                <p class="post-content">{{ message.content|nl2br }}</p>
            </article>
        {% endfor %}
    {% endif %}

    <div class="card">
        {{ form_start(messageForm) }}
            {{ form_errors(messageForm) }}
            {{ form_row(messageForm.content) }}
            <button type="submit">Envoyer</button>
        {{ form_end(messageForm) }}
    </div>
{% endblock %}
