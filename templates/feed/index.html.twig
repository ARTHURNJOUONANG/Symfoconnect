{% extends 'base.html.twig' %}

{% block title %}Mon feed | SymfoConnect{% endblock %}

{% block body %}
    <h1 class="section-title">Mon feed</h1>

    {% if not hasFollows %}
        <div class="card">
            <p>Vous ne suivez encore personne. Allez sur des profils pour commencer a suivre des utilisateurs.</p>
        </div>
    {% elseif posts is empty %}
        <div class="card">
            <p>Aucun post recent dans votre feed.</p>
        </div>
    {% else %}
        {% for post in posts %}
            <article class="card">
                <p class="post-content">{{ post.content|nl2br }}</p>
                <p class="post-meta">
                    Par <a href="{{ path('app_profile_show', { username: post.author.username }) }}">{{ post.author.username }}</a>
                    · {{ post.createdAt|date('d/m/Y H:i') }}
                    · {{ post.likesCount }} like(s)
                </p>
                <div class="post-actions">
                    <form method="post" action="{{ path('app_post_like_toggle', { id: post.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('like_post_' ~ post.id) }}">
                        <button type="submit" class="action-btn">
                            {{ post.isLikedBy(app.user) ? 'Unlike' : 'Like' }}
                        </button>
                    </form>

                    {% if app.user and app.user.id == post.author.id %}
                        <form method="post" action="{{ path('app_post_delete', { id: post.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                            <button type="submit" class="action-btn">Supprimer</button>
                        </form>
                    {% endif %}
                </div>
            </article>
        {% endfor %}
    {% endif %}
{% endblock %}
