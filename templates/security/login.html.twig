{% extends 'base.html.twig' %}

{% block title %}Connexion | SymfoConnect{% endblock %}

{% block body %}
    <h1 class="section-title">Connexion</h1>

    <div class="card">
        {% if error %}
            <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="{{ lastUsername }}" required autofocus>

            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="password" required>

            <button type="submit">Se connecter</button>
        </form>
    </div>
{% endblock %}
